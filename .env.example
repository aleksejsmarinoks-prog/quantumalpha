# QuantumAlpha — Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════
# TELEGRAM
# ═══════════════════════════════════════════════════════════════════════
BOT_TOKEN=your_bot_token_from_BotFather
ALLOWED_USER_ID=your_telegram_user_id_from_userinfobot

# ═══════════════════════════════════════════════════════════════════════
# BYBIT API
# ═══════════════════════════════════════════════════════════════════════
# Generate at: bybit.com → Account → API Management
# REQUIRED PERMISSIONS: Read-Write for Spot + Derivatives
# CRITICAL: Withdrawal MUST be DISABLED (set to no permission)
# CRITICAL: IP whitelist MUST be set to your VPS IP only
#
# For paper-mode validation phase: leave empty (public endpoints work without keys)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Use testnet for development?
BYBIT_TESTNET=false

# ═══════════════════════════════════════════════════════════════════════
# CAPITAL & RISK
# ═══════════════════════════════════════════════════════════════════════
# Starting equity for active trading layer (USD)
INITIAL_CAPITAL_USD=1000

# Default mode: paper (no real orders) until explicitly enabled
LIVE_TRADING=false

# Risk per trade (% of equity at risk per single trade)
RISK_PER_TRADE_PCT=1.0

# Max daily drawdown before 24h halt
DAILY_DD_LIMIT_PCT=5.0

# Max weekly drawdown before 7d halt
WEEKLY_DD_LIMIT_PCT=10.0

# ═══════════════════════════════════════════════════════════════════════
# MACRO PIPELINE (legacy QA system)
# ═══════════════════════════════════════════════════════════════════════
# Killswitch alert thresholds
VIX_ALERT_THRESHOLD=35
VIX_S13_THRESHOLD=25
GOLD_MOVE_PCT_ALERT=3.0
OIL_MOVE_PCT_ALERT=5.0

# Cron schedule for QA pipeline runs
PIPELINE_CRON=0 6,12,18 * * *

# ═══════════════════════════════════════════════════════════════════════
# STRATEGIES (off by default)
# ═══════════════════════════════════════════════════════════════════════
STRATEGY_FUNDING_ARB_ENABLED=false
STRATEGY_BASIS_TRADE_ENABLED=false
STRATEGY_MEAN_REVERSION_ENABLED=false

# Funding arb thresholds
FUNDING_ARB_MIN_RATE_PCT_PER_8H=0.05    # Open arb when funding > 0.05%/8h
FUNDING_ARB_CLOSE_RATE_PCT_PER_8H=0.01  # Close when funding drops below 0.01%

# ═══════════════════════════════════════════════════════════════════════
# TRACKING & EXPORT
# ═══════════════════════════════════════════════════════════════════════
# Google Sheets equity curve URL (optional, for public tracker)
EQUITY_TRACKER_SHEET_ID=

# Snapshot interval in minutes
EQUITY_SNAPSHOT_INTERVAL_MIN=60

# ═══════════════════════════════════════════════════════════════════════
# ANTHROPIC API (for QA macro analysis — optional)
# ═══════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=
